# =========================
# Telegram 管理机器人配置文件（.env）
# 说明：
# 1) 标记为【必填】的项必须修改，否则无法正常工作。
# 2) 其他项为【可选】，不改会使用默认值。
# =========================

# 【必填】Telegram Bot Token（从 @BotFather 获取）
BOT_TOKEN=replace-with-telegram-bot-token

# 【可选】OpenAI API Key（启用 AI 判定时建议填写；不填则 AI 功能不可用）
OPENAI_API_KEY=replace-with-openai-key

# 【可选】OpenAI 兼容接口 Base URL（接第三方模型平台时填写）
# 例如：https://api.openai.com/v1 或第三方兼容网关地址
OPENAI_BASE_URL=

# 【可选】运行模式：polling（开发）/ webhook（生产）
RUN_MODE=polling

# 【可选】日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# 【可选】SQLite 数据库文件路径
DB_PATH=data/bot.db

# =========================
# Webhook 配置（仅 RUN_MODE=webhook 时生效）
# =========================

# 【可选】HTTP 监听地址
WEBHOOK_HOST=0.0.0.0

# 【可选】Webhook 服务端口
WEBHOOK_PORT=8080

# 【必填（Webhook 模式）】公网 HTTPS 地址，例如 https://bot.example.com
WEBHOOK_PUBLIC_URL=https://example.com

# 【可选】Telegram 回调路径
WEBHOOK_PATH=/telegram/webhook

# =========================
# 内置管理 API 配置
# =========================

# 【可选】是否启用管理 API：1=启用，0=关闭
HTTP_API_ENABLED=1

# 【可选】管理 API 监听地址
HTTP_API_HOST=0.0.0.0

# 【可选】管理 API 端口
HTTP_API_PORT=8080

# 【必填（启用管理 API 时）】管理 API 访问令牌，请改成随机字符串
ADMIN_API_TOKEN=change-me

# =========================
# 默认策略配置（群级未覆盖时使用）
# =========================

# 【可选】群默认模式：strict / balanced / relaxed
DEFAULT_MODE=balanced

# 【可选】默认是否启用 AI：1=启用，0=关闭
DEFAULT_AI_ENABLED=1

# 【可选】AI 置信度阈值（0~1）；低于阈值会降级高风险动作
DEFAULT_AI_THRESHOLD=0.75

# 【可选】动作策略（当前实现为 progressive）
DEFAULT_ACTION_POLICY=progressive

# 【可选】速率策略标识（预留字段）
DEFAULT_RATE_LIMIT_POLICY=default

# 【可选】默认语言（如 zh / en）
DEFAULT_LANGUAGE=zh

# 【可选】Level 3 默认禁言时长（秒），604800=7天
DEFAULT_LEVEL3_MUTE_SECONDS=604800

# =========================
# AI 模型配置
# =========================

# 【可选】低风险消息使用的模型
AI_LOW_RISK_MODEL=gpt-4.1-mini

# 【可选】中高风险消息使用的模型
AI_HIGH_RISK_MODEL=gpt-5.2

# 【可选】AI 调用超时时间（秒）
AI_TIMEOUT_SECONDS=12
