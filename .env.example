# ============================================================
# Telegram 管理机器人（基础启动配置）
# 说明：
# 1) 业务配置（BOT_TOKEN、模型、管理令牌等）已迁移到前端向导，不再在 .env 填写。
# 2) .env 仅用于基础运行参数，通常无需修改。
# ============================================================

# 日志级别
LOG_LEVEL=INFO

# SQLite 数据库路径
DB_PATH=data/bot.db

# HTTP 服务监听地址与端口（浏览器访问的后端地址）
HTTP_API_HOST=0.0.0.0
HTTP_API_PORT=10010

# Webhook 服务监听地址与端口（仅 webhook 模式下由运行配置使用）
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=10010

# 跨域白名单（独立前端开发模式）
HTTP_API_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# 内置前端构建产物目录
WEB_ADMIN_DIST_PATH=web-admin/dist
